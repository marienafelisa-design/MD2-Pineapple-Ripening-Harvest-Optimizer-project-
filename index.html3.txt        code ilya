    <!-- MATHEMATICS AND CHARTING INTERACTION ENGINE (JAVASCRIPT) -->
    <script>
        // Mathematical Coefficients for Scenarios
        // Model formula format: f(x) = A*t^3 + B*t^2 + C*t + D where t = x - 100
        const scenarios = {
            baseline: {
                A: -0.00015,
                B: 0.0075,
                C: 0.1,
                D: 8.0,
                latex_f: "f(x) = -0.00015(x-100)^3 + 0.0075(x-100)^2 + 0.1(x-100) + 8.0",
                latex_df: "f'(x) = -0.00045(x-100)^2 + 0.015(x-100) + 0.1"
            },
            foliar: {
                A: -0.00018,
                B: 0.009,
                C: 0.15,
                D: 8.2,
                latex_f: "f(x) = -0.00018(x-100)^3 + 0.009(x-100)^2 + 0.15(x-100) + 8.2",
                latex_df: "f'(x) = -0.00054(x-100)^2 + 0.018(x-100) + 0.15"
            },
            heatstress: {
                A: -0.00011,
                B: 0.005,
                C: 0.08,
                D: 7.5,
                latex_f: "f(x) = -0.00011(x-100)^3 + 0.005(x-100)^2 + 0.08(x-100) + 7.5",
                latex_df: "f'(x) = -0.00033(x-100)^2 + 0.010(x-100) + 0.08"
            }
        };

        // UI Element References
        const scenarioSelect = document.getElementById('scenarioSelect');
        const daySlider = document.getElementById('daySlider');
        const sliderBubble = document.getElementById('sliderBubble');
        const resultDayTag = document.getElementById('result-day-tag');
        const calcSugar = document.getElementById('calc-sugar');
        const calcGrade = document.getElementById('calc-grade');
        const calcRate = document.getElementById('calc-rate');
        const calcAccelStatus = document.getElementById('calc-accel-status');
        const calcExplanation = document.getElementById('calc-explanation');
        const fxFormulaDiv = document.getElementById('fx-formula');
        const dfxFormulaDiv = document.getElementById('dfx-formula');

        let currentScenario = 'baseline';
        let selectedDay = 120;
        let chartInstance = null;

        // Mathematical evaluation helpers
        function getSugarLevel(day, scenarioKey) {
            const sc = scenarios[scenarioKey];
            const t = day - 100;
            return (sc.A * Math.pow(t, 3)) + (sc.B * Math.pow(t, 2)) + (sc.C * t) + sc.D;
        }

        function getSugarRate(day, scenarioKey) {
            const sc = scenarios[scenarioKey];
            const t = day - 100;
            // Derivative f'(t) = 3*A*t^2 + 2*B*t + C
            return (3 * sc.A * Math.pow(t, 2)) + (2 * sc.B * t) + sc.C;
        }

        // Generate entire range data points (Day 100 - 140)
        function generateDataset(scenarioKey) {
            const labels = [];
            const sugarLevels = [];
            const sugarRates = [];

            for (let day = 100; day <= 140; day++) {
                labels.push(day);
                sugarLevels.push(parseFloat(getSugarLevel(day, scenarioKey).toFixed(3)));
                sugarRates.push(parseFloat(getSugarRate(day, scenarioKey).toFixed(3)));
            }
            return { labels, sugarLevels, sugarRates };
        }

        // DYNAMIC ANALYSIS EXPLAINER GENERATOR
        function renderInsightAndExplainer(day, sugar, rate, scenarioKey) {
            // Day thresholds and standard interpretations
            let text = "";
            let grade = "";
            let accelStatus = "";
            let gradeColor = "text-emerald-400";
            let accelColor = "text-amber-400";

            if (day < 110) {
                grade = "LPNM Index 1 (Hard Green)";
                accelStatus = "Slow Synthesis";
                text = `At Day ${day}, the pineapple is in its early maturation phase. Total soluble solids are low (${sugar.toFixed(2)} °Brix) and accumulation speed is minimal (${rate.toFixed(3)} °Brix/day). Harvesting now is highly unfeasible for eating quality, yielding a high-acid, astringent fruit with raw white flesh. Suitable only for extremely long-distance sea shipments.`;
            } 
            else if (day >= 110 && day <= 122) {
                grade = "LPNM Index 2-3 (Mature Green/Eyes-Greening)";
                accelStatus = "Sugar Velocity Peak";
                text = `At Day ${day}, the fruit is in its prime sugar synthesis stage. The derivative \( f'(x) \) is at or near its peak value (${rate.toFixed(3)} °Brix/day), meaning sucrose translocation from leaves is operating at maximum speed. This is the physiological transition point; harvesting now produces crisp fresh-cut fruits but the sugar profile is not yet finalized.`;
            } 
            else if (day > 122 && day <= 134) {
                grade = "LPNM Index 4 (50% Golden Yellow)";
                accelStatus = "Ripening Plateau";
                text = `At Day ${day}, you have reached the **Optimal Agro-Industrial Harvest Window**. Although the derivative is slowing down (${rate.toFixed(3)} °Brix/day), sugar content has maximized to a premium grade (${sugar.toFixed(2)} °Brix). Perfect balance of volatile esters (sweet aroma), ascorbic acid, and pulp firmness. Ideal for high-end raw export and canning.`;
            } 
            else {
                grade = "LPNM Index 5-6 (Overripe Orange)";
                accelStatus = "Senescence / Respiration Deficit";
                text = `At Day ${day}, the fruit is entering over-ripeness and cellular senescence. The rate of sugar accumulation has dropped to near-zero or gone negative (${rate.toFixed(3)} °Brix/day) because the pineapple is consuming stored sugars via intracellular respiration faster than synthesizing them. Highly prone to bruising, alcohol fermentation, and watery pulp. Process immediately!`;
            }

            // Scenario specific adjusters to customize educational feedback
            if (scenarioKey === 'foliar') {
                text += ` (Potassium supplementation has boosted overall translocation rates by ~20%, raising final Brix and speeding shelf maturity.)`;
            } else if (scenarioKey === 'heatstress') {
                text += ` (Heat/drought stress has compromised cellular respiration and enzyme efficiency, forcing early sugar stabilization and low-quality, sour fruits.)`;
            }

            // Update DOM Elements
            resultDayTag.innerText = `DAY ${day}`;
            calcSugar.innerHTML = `${sugar.toFixed(2)} <span class="text-sm font-semibold text-slate-400">°Brix</span>`;
            calcGrade.innerText = grade;
            calcRate.innerHTML = `${rate >= 0 ? '+' : ''}${rate.toFixed(3)} <span class="text-xs font-semibold text-slate-400">°Brix/d</span>`;
            calcAccelStatus.innerText = accelStatus;
            calcExplanation.innerHTML = text;

            // Trigger KaTeX rendering specifically inside the dynamic text
            if (window.renderMathInElement) {
                window.renderMathInElement(calcExplanation);
            }
        }

        // INITIALIZE AND UPDATE INTERACTIVE CHART
        function initChart() {
            const ctx = document.getElementById('kineticsChart').getContext('2d');
            const dataObj = generateDataset(currentScenario);

            // Custom Chart.js dynamic vertical indicator vertical line plugin
            const verticalLinePlugin = {
                id: 'verticalLine',
                afterDraw: (chart) => {
                    if (selectedDay) {
                        const activeIndex = selectedDay - 100;
                        const meta = chart.getDatasetMeta(0);
                        if(meta.data[activeIndex]) {
                            const x = meta.data[activeIndex].x;
                            const ctx = chart.ctx;
                            ctx.save();
                            ctx.beginPath();
                            ctx.moveTo(x, chart.chartArea.top);
                            ctx.lineTo(x, chart.chartArea.bottom);
                            ctx.lineWidth = 1.5;
                            ctx.setLineDash([5, 5]);
                            ctx.strokeStyle = '#334155'; // Dark slate line indicator
                            ctx.stroke();
                            ctx.restore();
                        }
                    }
                }
            };

            chartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: dataObj.labels,
                    datasets: [
                        {
                            label: 'Absolute Sugar Level f(x) (°Brix)',
                            data: dataObj.sugarLevels,
                            borderColor: '#059669', // Emerald Green
                            backgroundColor: 'rgba(5, 150, 105, 0.05)',
                            borderWidth: 3.5,
                            yAxisID: 'ySugar',
                            tension: 0.3,
                            pointBackgroundColor: '#047857',
                            pointBorderColor: '#fff',
                            pointHoverRadius: 8,
                            pointHoverBorderWidth: 3,
                            fill: true
                        },
                        {
                            label: "Accumulation Rate f'(x) (°Brix/day)",
                            data: dataObj.sugarRates,
                            borderColor: '#f59e0b', // Amber/Yellow
                            backgroundColor: 'transparent',
                            borderWidth: 2.5,
                            borderDash: [2, 2],
                            yAxisID: 'yRate',
                            tension: 0.3,
                            pointBackgroundColor: '#d97706',
                            pointBorderColor: '#fff',
                            pointHoverRadius: 8,
                            pointHoverBorderWidth: 3
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'index',
                        intersect: false,
                    },
                    plugins: {
                        legend: {
                            display: false // Using standard customized HTML legend instead
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    if (context.parsed.y !== null) {
                                        label += context.parsed.y;
                                    }
                                    return label;
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            title: {
                                display: true,
                                text: 'Days Post-Anthesis (Maturation Stage)',
                                color: '#475569',
                                font: {
                                    weight: 'bold',
                                    size: 11
                                }
                            },
                            grid: {
                                color: '#f1f5f9'
                            }
                        },
                        ySugar: {
                            type: 'linear',
                            display: true,
                            position: 'left',
                            min: 6,
                            max: 18,
                            title: {
                                display: true,
                                text: 'Absolute Sugar Level (°Brix)',
                                color: '#059669',
                                font: {
                                    weight: 'bold',
                                    size: 11
                                }
                            },
                            grid: {
                                color: '#e2e8f0'
                            }
                        },
                        yRate: {
                            type: 'linear',
                            display: true,
                            position: 'right',
                            min: -0.1,
                            max: 0.35,
                            title: {
                                display: true,
                                text: 'Accumulation Rate (°Brix/Day)',
                                color: '#f59e0b',
                                font: {
                                    weight: 'bold',
                                    size: 11
                                }
                            },
                            grid: {
                                drawOnChartArea: false // prevent grid line overlap interference
                            }
                        }
                    },
                    onClick: (event, elements) => {
                        // Interactive Graph Click to display calculated rate of change & analytical updates
                        if (elements.length > 0) {
                            const index = elements[0].index;
                            const clickedDay = 100 + index;
                            updateInterface(clickedDay);
                        }
                    }
                },
                plugins: [verticalLinePlugin]
            });
        }

        // UPDATE SCENARIO OR SLIDER DATA DYNAMICALLY
        function updateInterface(day, refreshChartData = false) {
            selectedDay = parseInt(day);
            daySlider.value = selectedDay;
            sliderBubble.innerText = `${selectedDay} d`;

            const sugar = getSugarLevel(selectedDay, currentScenario);
            const rate = getSugarRate(selectedDay, currentScenario);

            // Trigger text and calculus dynamic engine update
            renderInsightAndExplainer(selectedDay, sugar, rate, currentScenario);

            // Re-render chart vertical marker line
            if (chartInstance) {
                if (refreshChartData) {
                    const newDataset = generateDataset(currentScenario);
                    chartInstance.data.datasets[0].data = newDataset.sugarLevels;
                    chartInstance.data.datasets[1].data = newDataset.sugarRates;
                }
                chartInstance.update();
            }
        }

        // EVENT HANDLERS & INITIAL RUNTIME ATTACHMENT
        window.addEventListener('load', () => {
            // Render KaTeX Formulas for the first time
            if (window.katex) {
                katex.render(scenarios.baseline.latex_f, fxFormulaDiv);
                katex.render(scenarios.baseline.latex_df, dfxFormulaDiv);
            }

            // Init Chart
            initChart();

            // Run initial explanation cycle
            updateInterface(120);
        });

        // Trigger on Scenario Select dropdown change
        scenarioSelect.addEventListener('change', (e) => {
            currentScenario = e.target.value;

            // Render updated math equations
            if (window.katex) {
                katex.render(scenarios[currentScenario].latex_f, fxFormulaDiv);
                katex.render(scenarios[currentScenario].latex_df, dfxFormulaDiv);
            }

            // Update user view and refresh datasets
            updateInterface(selectedDay, true);
        });

        // Trigger on Manual Range slider adjustment
        daySlider.addEventListener('input', (e) => {
            updateInterface(e.target.value, false);
        });
    </script>
</body>
</html>